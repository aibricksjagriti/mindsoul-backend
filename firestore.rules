rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // USERS COLLECTION
    // ============================================================
    match /users/{userId} {

      // User can read/update/delete ONLY their own profile
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;

      // Allow authenticated users to create their own profile specifically (prevents spoofing)
      allow create: if request.auth != null && request.auth.uid == userId;

      // Each user has a subcollection of appointments
      match /appointments/{appointmentId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ============================================================
    // COUNSELLORS COLLECTION (PUBLIC READ ALLOWED)
    // ============================================================
    match /counsellors/{counsellorId} {

      // Anyone can view counsellor profile
      allow read: if true;

      // Counsellor can update only their own profile
      allow update, delete: if request.auth != null
                            && request.auth.token.email == counsellorId;

      // Anyone authenticated can create their own counsellor doc (onboarding)
      allow create: if request.auth != null && request.auth.token.email == counsellorId;

      // -----------------------------------------
      // Counsellor appointments subcollection
      // -----------------------------------------
      match /appointments/{appointmentId} {
        // SECURED: Only the counsellor or the specific student can access/modify
        allow read: if request.auth != null && 
                    (request.auth.token.email == counsellorId || request.auth.uid == resource.data.studentId);
                    
        // Prevent frontend from spoofing payment success
        allow update: if request.auth != null && 
                     (request.auth.token.email == counsellorId || request.auth.uid == resource.data.studentId) &&
                     (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['paymentStatus', 'paymentDetails', 'orderId', 'paymentId']));
                     
        allow create: if request.auth != null && 
                      (request.auth.uid == request.resource.data.studentId);
                      
        allow delete: if request.auth != null && 
                     (request.auth.token.email == counsellorId || request.auth.uid == resource.data.studentId);
      }

      // -----------------------------------------
      // NEW: schedulePreferences document
      // /counsellors/{id}/schedulePreferences
      // -----------------------------------------
      match /schedulePreferences/{prefId} {
        // Only this counsellor can read/write their schedule config
        allow read, write: if request.auth != null
                           && request.auth.token.email == counsellorId;
      }

      // -----------------------------------------
      // NEW: exceptions subcollection
      // /counsellors/{id}/exceptions/{date}
      // -----------------------------------------
      match /exceptions/{date} {
        // Only this counsellor can manage their exceptions
        allow read, write, delete: if request.auth != null
                                   && request.auth.token.email == counsellorId;
      }
    }

    // ============================================================
    // MASTER APPOINTMENTS COLLECTION
    // ============================================================
    match /appointments/{appointmentId} {
      // SECURED: Only the student who booked it or the counsellor assigned to it can access/modify
      allow read: if request.auth != null && 
                  (request.auth.uid == resource.data.studentId || request.auth.token.email == resource.data.counsellorId);
                  
      // Prevent frontend from spoofing payment success
      allow update: if request.auth != null && 
                   (request.auth.uid == resource.data.studentId || request.auth.token.email == resource.data.counsellorId) &&
                   (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['paymentStatus', 'paymentDetails', 'orderId', 'paymentId', 'paidAt']));
                   
      allow create: if request.auth != null && 
                    (request.auth.uid == request.resource.data.studentId);
                    
      allow delete: if request.auth != null && 
                   (request.auth.uid == resource.data.studentId || request.auth.token.email == resource.data.counsellorId);
    }

    // ============================================================
    // TIMESLOTS COLLECTION
    // ============================================================
    match /timeSlots/{slotId} {

      // Public read allowed → needed for showing available slots
      allow read: if true;

      // IMPORTANT:
      // Frontend must NOT write timeSlots.
      // Only backend (Admin SDK) bypasses rules.
      allow create, update, delete: if false;
    }

    // ============================================================
    // DEFAULT RULE — DENY EVERYTHING ELSE
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
